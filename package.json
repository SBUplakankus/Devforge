{
  "name": "devforge",
  "private": true,
  "version": "1.0.0",
  "description": "Devforge desktop app powered by Electron and Vite",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron . --dev\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --win --publish never",
    "start": "npm run build && electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.devforge.app",
    "productName": "Devforge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
